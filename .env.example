# === Security ===

# API key for authenticating requests to the Go bridge REST API.
# Both the bridge and MCP server must share the same key.
# Generate one: openssl rand -hex 32
WHATSAPP_API_KEY=

# Read-only mode (default: true). Set to false to enable send_message, send_file, send_audio_message.
WHATSAPP_READ_ONLY=true

# Restrict send_file/send_audio_message to files within this directory only.
# Leave empty to allow any path (not recommended when READ_ONLY=false).
WHATSAPP_MEDIA_DIR=

# === Bridge Configuration ===

# Port for the Go bridge REST API
WHATSAPP_BRIDGE_PORT=8080

# Max messages per minute via /api/send (default: 5)
WHATSAPP_RATE_LIMIT=5

# Bind to all interfaces (default: false, binds to 127.0.0.1 only)
WHATSAPP_BIND_ALL=false

# Forward messages sent by yourself to the webhook
FORWARD_SELF=false

# Webhook URL for incoming messages (leave empty to disable)
WEBHOOK_URL=

# === MCP Server Configuration ===

# Path to the SQLite messages database
WHATSAPP_DB_PATH=../whatsapp-bridge/store/messages.db

# Go bridge API URL
WHATSAPP_API_URL=http://localhost:8080/api
